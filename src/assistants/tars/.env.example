# Copy this file to `.env` for the scenario assistant.
# Supported providers: "openai-api", "openai-codex", "claude-api"
LLM_PROVIDER=openai-api

# Required for OpenAI API mode.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# ChatGPT / Codex subscription route.
OPENAI_CODEX_COMMAND=codex
# Leave empty for the Codex default. Use gpt-5.3-codex-spark for Codex Spark.
OPENAI_CODEX_MODEL=

# Required only for Anthropic API mode.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Optional shared reasoning fallback. Provider/model support varies.
LLM_REASONING_EFFORT=

# Local MCP servers. Relative paths are resolved from this `.env` file.
MCP_SERVERS=[{"name":"cognition","command":"../../tools/cognition/bin/Debug/net10.0-windows/cognition.exe"},{"name":"execution","command":"../../tools/execution/bin/Debug/net10.0-windows/execution.exe"}]
NETFLIX_PROFILE_PIN=

# Optional debugging and context settings.
MAX_CONTEXT_TOKENS=128000
POST_ACTION_UI_SETTLE_DELAY_MS=1000
DEBUG_TRACE=false
