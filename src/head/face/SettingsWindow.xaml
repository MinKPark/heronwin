<Window x:Class="HeronWin.Face.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="face settings"
        Width="760"
        Height="700"
        WindowStartupLocation="CenterOwner"
        Background="#0B1020">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="face settings" FontSize="28" FontWeight="SemiBold" />
                <TextBlock Text="Edit face behavior and the brain .env values without hand-editing raw environment files."
                           Margin="0,8,0,0"
                           Foreground="{StaticResource MutedTextBrush}"
                           TextWrapping="Wrap" />
            </StackPanel>

            <Border Grid.Row="1" Margin="0,20,0,0" Padding="18" CornerRadius="18" Background="#88111827" BorderBrush="#223449" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="brain env file" FontWeight="SemiBold" />
                        <TextBox Margin="0,10,0,0" Text="{Binding EnvFilePath, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Margin="0,10,0,0" Text="named pipe" FontWeight="SemiBold" />
                        <TextBox Margin="0,10,0,0" Text="{Binding PipeName, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <Button Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Top" Content="reload" Style="{StaticResource GhostButtonStyle}" Command="{Binding ReloadEnvCommand}" />
                </Grid>
            </Border>

            <Border Grid.Row="2" Margin="0,18,0,0" Padding="18" CornerRadius="18" Background="#88111827" BorderBrush="#223449" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,14,0">
                        <TextBlock Text="provider and voice" FontWeight="SemiBold" />
                        <TextBlock Margin="0,14,0,0" Text="LLM provider" />
                        <TextBox Margin="0,6,0,0" Text="{Binding LlmProvider, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Margin="0,14,0,0" Text="OpenAI model" />
                        <TextBox Margin="0,6,0,0" Text="{Binding OpenAiModel, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Margin="0,14,0,0" Text="OpenAI Codex model" />
                        <TextBox Margin="0,6,0,0" Text="{Binding OpenAiCodexModel, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Margin="0,14,0,0" Text="Claude model" />
                        <TextBox Margin="0,6,0,0" Text="{Binding AnthropicModel, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Margin="0,14,0,0" Text="Whisper model" />
                        <TextBox Margin="0,6,0,0" Text="{Binding WhisperModel, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Margin="0,14,0,0" Text="TTS voice" />
                        <TextBox Margin="0,6,0,0" Text="{Binding TtsVoice, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Margin="14,0,0,0" Grid.Column="1">
                        <TextBlock Text="runtime behavior" FontWeight="SemiBold" />
                        <TextBlock Margin="0,14,0,0" Text="Wake word" />
                        <TextBox Margin="0,6,0,0" Text="{Binding WakeWord, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Margin="0,14,0,0" Text="Voice languages" />
                        <TextBox Margin="0,6,0,0" Text="{Binding VoiceLanguages, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Margin="0,14,0,0" Text="Max record ms" />
                        <TextBox Margin="0,6,0,0" Text="{Binding MaxRecordMs, UpdateSourceTrigger=PropertyChanged}" />
                        <CheckBox Margin="0,14,0,0" Content="Enable debug trace" IsChecked="{Binding DebugTrace}" />
                        <CheckBox Margin="0,10,0,0" Content="Enable debug audio playback" IsChecked="{Binding DebugAudioPlayback}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="3" Margin="0,18,0,0" Padding="18" CornerRadius="18" Background="#88111827" BorderBrush="#223449" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="keys and MCP" FontWeight="SemiBold" />
                    <TextBlock Margin="0,14,0,0" Text="OpenAI API key" />
                    <PasswordBox x:Name="OpenAiKeyBox" Margin="0,6,0,0" PasswordChanged="OpenAiKeyBox_OnPasswordChanged" />
                    <TextBlock Margin="0,14,0,0" Text="Anthropic API key" />
                    <PasswordBox x:Name="AnthropicKeyBox" Margin="0,6,0,0" PasswordChanged="AnthropicKeyBox_OnPasswordChanged" />
                    <TextBlock Margin="0,14,0,0" Text="MCP_SERVERS JSON" />
                    <TextBox Margin="0,6,0,0"
                             MinHeight="140"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Text="{Binding McpServersJson, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </Border>

            <Border Grid.Row="4" Margin="0,18,0,0" Padding="18" CornerRadius="18" Background="#88111827" BorderBrush="#223449" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="advanced raw env" FontWeight="SemiBold" />
                    <TextBlock Margin="0,8,0,0" Text="Unknown keys and comments are preserved when possible."
                               Foreground="{StaticResource MutedTextBrush}" />
                    <TextBox Margin="0,12,0,0"
                             MinHeight="220"
                             AcceptsReturn="True"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             Text="{Binding RawEnvPreview}" IsReadOnly="True" />
                </StackPanel>
            </Border>

            <Border Grid.Row="5" Margin="0,18,0,0" Padding="16" CornerRadius="14" Background="#332A1306" BorderBrush="#7C2D12" BorderThickness="1">
                <TextBlock Text="{Binding SaveMessage}" TextWrapping="Wrap" />
            </Border>

            <StackPanel Grid.Row="6" Margin="0,18,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="save" Style="{StaticResource GhostButtonStyle}" Command="{Binding SaveCommand}" />
                <Button Content="close" Style="{StaticResource GhostButtonStyle}" Click="Close_OnClick" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>
