<Window x:Class="HeronWin.Face.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="her face"
        Width="350"
        Height="420"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="Transparent"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Topmost="True">
    <Border Margin="18"
            CornerRadius="28"
            Background="#DD0B1020"
            BorderBrush="#334155"
            BorderThickness="1">
        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="her"
                               FontSize="26"
                               FontWeight="SemiBold" />
                    <TextBlock Text="desktop companion"
                               FontSize="12"
                               Foreground="{StaticResource MutedTextBrush}" />
                </StackPanel>

                <Button Grid.Column="1"
                        Width="38"
                        Height="38"
                        Content="×"
                        FontSize="18"
                        Style="{StaticResource GhostButtonStyle}"
                        Command="{Binding HideCommand}" />
            </Grid>

            <Grid Grid.Row="1" Margin="0,18,0,18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid x:Name="AvatarRoot"
                      HorizontalAlignment="Center"
                      Margin="0,0,0,16"
                      RenderTransformOrigin="0.5,0.5">
                    <Grid.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="AvatarScaleTransform" ScaleX="1" ScaleY="1" />
                            <RotateTransform x:Name="AvatarRotateTransform" Angle="0" />
                            <TranslateTransform x:Name="AvatarTranslateTransform" X="0" Y="0" />
                        </TransformGroup>
                    </Grid.RenderTransform>
                    <Ellipse x:Name="AuraEllipse" Width="160" Height="160" Opacity="0.92">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="{Binding AccentColor}" Offset="0" />
                                <GradientStop Color="#0F172A" Offset="1" />
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <Ellipse Width="130" Height="130" Fill="#E6121828" />
                    <Ellipse x:Name="LeftEye"
                             Width="16"
                             Height="16"
                             Fill="White"
                             Margin="-34,-12,0,0"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <ScaleTransform x:Name="LeftEyeScaleTransform" ScaleX="1" ScaleY="1" />
                        </Ellipse.RenderTransform>
                    </Ellipse>
                    <Ellipse x:Name="RightEye"
                             Width="16"
                             Height="16"
                             Fill="White"
                             Margin="34,-12,0,0"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <ScaleTransform x:Name="RightEyeScaleTransform" ScaleX="1" ScaleY="1" />
                        </Ellipse.RenderTransform>
                    </Ellipse>
                    <Path x:Name="MouthPath"
                          Stroke="White"
                          StrokeThickness="5"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Data="{Binding MouthGeometry}"
                          Margin="0,32,0,0"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <ScaleTransform x:Name="MouthScaleTransform" ScaleX="1" ScaleY="1" />
                        </Path.RenderTransform>
                    </Path>
                </Grid>

                <Border Grid.Row="1"
                        HorizontalAlignment="Center"
                        Padding="12,6"
                        CornerRadius="999"
                        Background="{Binding AccentBrush}">
                    <TextBlock Text="{Binding StatusLabel}" FontWeight="SemiBold" />
                </Border>

                <StackPanel Grid.Row="2" Margin="0,16,0,0">
                    <TextBlock Text="{Binding Headline}"
                               TextAlignment="Center"
                               FontSize="22"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding Detail}"
                               Margin="0,8,0,0"
                               TextAlignment="Center"
                               Foreground="{StaticResource MutedTextBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>

                <Border Grid.Row="3"
                        Margin="0,18,0,0"
                        Padding="14"
                        CornerRadius="18"
                        Background="#88111827"
                        BorderBrush="#223449"
                        BorderThickness="1">
                    <DockPanel LastChildFill="True">
                        <TextBlock DockPanel.Dock="Top"
                                   Text="recent activity"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Margin="0,0,0,8" />
                        <ItemsControl ItemsSource="{Binding ActivityLines}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Margin="0,0,0,6" TextWrapping="Wrap" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DockPanel>
                </Border>
            </Grid>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="settings"
                        Style="{StaticResource GhostButtonStyle}"
                        Command="{Binding OpenSettingsCommand}" />
                <Button Content="demo"
                        Style="{StaticResource GhostButtonStyle}"
                        Command="{Binding ToggleDemoCommand}" />
                <Button Content="pin"
                        Style="{StaticResource GhostButtonStyle}"
                        Command="{Binding TogglePinnedCommand}" />
            </StackPanel>
        </Grid>
    </Border>
</Window>