# Copy this file to `.env` for your local machine-specific config.
# Supported providers: "openai-api", "chatgpt-web", "claude-api"
LLM_PROVIDER=openai-api

# Required for OpenAI API mode and Whisper transcription.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Required only for Anthropic API mode.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Browser-backed ChatGPT settings.
CHATGPT_BASE_URL=https://chatgpt.com/
CHATGPT_BROWSER_CHANNEL=msedge
CHATGPT_HEADLESS=true

# Voice and speech settings.
WHISPER_MODEL=whisper-1
MAX_RECORD_MS=30000
ACTIVE_IDLE_TIMEOUT_MS=60000
WAKE_WORD=Hello there

# Local MCP servers.
MCP_SERVERS=[{"name":"process-manager","command":"node","args":["../../body/process-manager/dist/index.js"]},{"name":"cognition","command":"../../body/cognition/bin/Debug/net10.0-windows/cognition.exe"},{"name":"execution","command":"../../body/execution/bin/Debug/net10.0-windows/execution.exe"}]
NETFLIX_PROFILE_PIN=

# Optional debugging and context settings.
MAX_CONTEXT_TOKENS=128000
DEBUG_AUDIO_PLAYBACK=true
