# ── LLM Provider ──────────────────────────────────────────────
# Which LLM to use: "openai" or "claude"
LLM_PROVIDER=openai

# OpenAI (GPT) settings
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Anthropic (Claude) settings
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ── Voice / Speech-to-Text ─────────────────────────────────────
# Whisper model for speech-to-text transcription (uses OpenAI Whisper API)
WHISPER_MODEL=whisper-1

# Maximum recording duration in milliseconds before auto-stop (default: 30000)
MAX_RECORD_MS=30000

# ── MCP Servers ────────────────────────────────────────────────
# JSON array of MCP server configurations.
# Each entry requires: name, command, and optionally args and env.
#
# Example — connecting to the bundled process-manager server:
# MCP_SERVERS=[{"name":"process-manager","command":"node","args":["../herbody/process-manager/dist/index.js"]}]
MCP_SERVERS=[]
