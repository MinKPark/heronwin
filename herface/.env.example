# ── LLM Provider ──────────────────────────────────────────────
# Supported values: "openai-api", "chatgpt-web", "claude-api"
LLM_PROVIDER=chatgpt-web
AGENT_DEFINITION_PATH=.github/agents/her.agent.md

# OpenAI API settings
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2-chat-latest

# Anthropic API settings
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ChatGPT browser settings
CHATGPT_BASE_URL=https://chatgpt.com/
CHATGPT_BROWSER_CHANNEL=msedge
CHATGPT_PROFILE_DIR=.chatgpt-profile
CHATGPT_HEADLESS=true
CHATGPT_PROJECT_NAME=her
CHATGPT_SESSION_RETENTION_DAYS=14
CHATGPT_LOGIN_TIMEOUT_MS=900000
CHATGPT_STARTUP_TIMEOUT_MS=120000
CHATGPT_RESPONSE_TIMEOUT_MS=120000

# ── Voice / Speech-to-Text ────────────────────────────────────
# Voice transcription uses OpenAI Whisper whenever OPENAI_API_KEY is set.
WHISPER_MODEL=whisper-1
MAX_RECORD_MS=30000
DEBUG_AUDIO_PLAYBACK=false

# ── MCP Servers ───────────────────────────────────────────────
MCP_SERVERS=[]
