LLM_PROVIDER=openai-api
AGENT_DEFINITION_PATH=.github/agents/her.agent.md

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2-chat-latest
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=marin
TTS_INSTRUCTIONS=Speak warmly, softly, and naturally. Keep a calm, intimate, supportive tone with gentle pacing.

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

WHISPER_MODEL=whisper-1
MAX_RECORD_MS=30000
ACTIVE_IDLE_TIMEOUT_MS=60000
WAKE_WORD=Hello there
DEBUG_AUDIO_PLAYBACK=false

MCP_SERVERS=[]
